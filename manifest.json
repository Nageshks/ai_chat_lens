{
  "manifest_version": 3,
  "name": "AiChatLens",
  "version": "1.1.0",
  "description": "Adds a floating Table of Contents panel to AI chat platforms (Claude, Meta AI) for quick navigation of user questions in long conversations.",
  "permissions": ["storage", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.claude.ai/*", "*://*.meta.ai/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
